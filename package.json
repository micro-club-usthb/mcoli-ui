{
  "name": "mcoli-ui",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @mcoli/web dev",
    "build": "pnpm --filter @mcoli/web build",
    "start": "pnpm --filter @mcoli/web start",
    "lint": "pnpm --filter @mcoli/web lint",
    "typecheck": "pnpm --filter @mcoli/web typecheck",
    "storybook": "pnpm --filter @mcoli/web storybook",
    "build-storybook": "pnpm --filter @mcoli/web build-storybook",
    "cli": "pnpm --filter mcoli-ui",
    "cli:dev": "MCOLI_UI_REGISTRY_URL=http://localhost:3000 pnpm --filter mcoli-ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,mdx,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "eslint": "^9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2"
  }
}
