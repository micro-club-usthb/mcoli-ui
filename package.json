    "inquirer": "^12.10.0",
    "lucide-react": "^0.545.0",
    "next": "15.5.5",
    "ora": "^9.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1"
