  "css": {
    "h1, h2, h3, h4, h5, h6": {
      "font-family": "var(--font-plus-jakarta-sans)"
    },
    ".header-xl": {
      "font-size": "72px",
      "line-height": "90px",
      "letter-spacing": "-0.02em"
    },
    ".header-lg": {
      "font-size": "60px",
      "line-height": "72px",
      "letter-spacing": "-0.02em"
    },
    ".header-md": {
      "font-size": "36px",
      "line-height": "44px",
      "letter-spacing": "-0.02em"
    },
    ".header-sm": {
      "font-size": "30px",
      "line-height": "38px"
    },
    ".header-xs": {
      "font-size": "24px",
      "line-height": "32px"
    },
    ".paragraph-xl": {
      "font-size": "20px",
      "line-height": "30px"
    },
    ".paragraph-lg": {
      "font-size": "18px",
      "line-height": "28px"
    },
    ".paragraph-md": {
      "font-size": "16px",
      "line-height": "24px"
    },
    ".paragraph-sm": {
      "font-size": "14px",
      "line-height": "20px"
    },
    ".paragraph-xs": {
      "font-size": "12px",
      "line-height": "18px"
    },
    "@layer base": {
      "*": {
        "border-color": "var(--border)",
        "outline-color": "rgb(var(--ring) / 0.5)"
      },
      "body": {
        "background-color": "var(--background)",
        "color": "var(--foreground)",
        "letter-spacing": "0em"
      }
    }
