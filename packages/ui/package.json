  "scripts": {
    "dev": "next dev --turbopack",
    "build": "npm-run-all build:registry build:docs build:prod",
    "build:registry": "npm-run-all build:registry:internal build:registry:external",
    "build:registry:internal": "tsx --tsconfig ./tsconfig.scripts.json ./scripts/build-registry.mts",
    "build:registry:external": "shadcn build ./__registry__/registry.autogenerated.json",
    "build:docs": "fumadocs-mdx",
    "build:prod": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
