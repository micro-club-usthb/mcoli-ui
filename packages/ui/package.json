    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.11",
    "chromatic": "^16.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-storybook": "^10.3.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "shadcn": "^4.1.1",
    "storybook": "^10.3.3",
    "tailwindcss": "^4",
