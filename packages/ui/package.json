    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "^16.7.7",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@eslint/eslintrc": "^3",
